# ============================================
# Sports Academy Management System
# Environment Variables Template
# ============================================
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control
# ============================================

# ============================================
# Application Configuration
# ============================================
DEBUG=True
SECRET_KEY=django-insecure-change-this-in-production-min-50-chars
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
ENVIRONMENT=development
TIME_ZONE=UTC
LANGUAGE_CODE=en-us
USE_TZ=True
APP_NAME=Sports Academy
APP_VERSION=1.0.0

# ============================================
# Database Configuration
# ============================================
# Option 1: Use DATABASE_URL (recommended)
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/sports_academy_dev

# Option 2: Use individual variables
# DB_HOST=postgres
# DB_PORT=5432
# DB_NAME=sports_academy_dev
# DB_USER=postgres
# DB_PASSWORD=postgres
# DB_CONN_MAX_AGE=600
# DB_POOL_SIZE=10

# ============================================
# Redis Configuration
# ============================================
# Option 1: Use REDIS_URL (recommended)
REDIS_URL=redis://redis:6379/0

# Option 2: Use individual variables
# REDIS_HOST=redis
# REDIS_PORT=6379
# REDIS_DB=0
# REDIS_PASSWORD=
# REDIS_SSL=False

# ============================================
# JWT Authentication
# ============================================
JWT_SECRET_KEY=jwt-secret-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRATION=3600
JWT_REFRESH_TOKEN_EXPIRATION=604800
JWT_ISSUER=sports-academy
JWT_AUDIENCE=sports-academy-api

# ============================================
# Storage Configuration (MinIO for Development)
# ============================================
# MinIO Root Credentials (set in .env - never commit)
# For local dev only, MinIO image default is minioadmin/minioadmin; change for any shared/production use.
MINIO_ROOT_USER=your_minio_user
MINIO_ROOT_PASSWORD=your_minio_password

# S3-Compatible Storage Settings (use same as MinIO or your S3 keys)
AWS_ACCESS_KEY_ID=your_s3_access_key
AWS_SECRET_ACCESS_KEY=your_s3_secret_key
AWS_STORAGE_BUCKET_NAME=sports-academy-media
AWS_S3_ENDPOINT_URL=http://minio:9000
AWS_S3_REGION_NAME=us-east-1
AWS_S3_USE_SSL=False
AWS_S3_FILE_OVERWRITE=False
AWS_DEFAULT_ACL=private
AWS_S3_MAX_MEMORY_SIZE=10485760

# MinIO Ports (for docker-compose)
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# ============================================
# Google Cloud Storage (Production Only)
# ============================================
# GOOGLE_CLOUD_STORAGE_BUCKET=sports-academy-media-prod
# GOOGLE_CLOUD_STORAGE_PROJECT=sports-academy-prod
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# GOOGLE_CLOUD_PROJECT=sports-academy-prod
# GOOGLE_CLOUD_REGION=us-central1

# ============================================
# Celery Configuration
# ============================================
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
CELERY_TASK_SERIALIZER=json
CELERY_RESULT_SERIALIZER=json
CELERY_ACCEPT_CONTENT=["json"]
CELERY_TIMEZONE=UTC
CELERY_ENABLE_UTC=True
CELERY_TASK_TRACK_STARTED=True
CELERY_TASK_TIME_LIMIT=300
CELERY_TASK_SOFT_TIME_LIMIT=240

# ============================================
# Email Configuration
# ============================================
# Development: Use console backend (emails printed to console)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# Production: Use SMTP
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_USE_SSL=False
# EMAIL_HOST_USER=noreply@example.com
# EMAIL_HOST_PASSWORD=your-email-password
# EMAIL_FROM=noreply@example.com
# EMAIL_SUBJECT_PREFIX=[Sports Academy]

# ============================================
# Logging Configuration
# ============================================
LOG_LEVEL=DEBUG
LOG_FORMAT=text
# LOG_FILE=/var/log/app.log
# SENTRY_DSN=https://...@sentry.io/...
# SENTRY_ENVIRONMENT=development

# ============================================
# Security Configuration
# ============================================
# Development settings (set to True in production)
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False
SECURE_CONTENT_TYPE_NOSNIFF=True
SECURE_BROWSER_XSS_FILTER=True
X_FRAME_OPTIONS=DENY

# ============================================
# API Configuration
# ============================================
API_VERSION=v1
API_PAGE_SIZE=20
API_MAX_PAGE_SIZE=100
API_RATE_LIMIT=100

# ============================================
# Frontend Configuration
# ============================================
VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_APP_NAME=Sports Academy
VITE_APP_VERSION=1.0.0
VITE_ENVIRONMENT=development

# ============================================
# Docker Compose Port Overrides (Optional)
# ============================================
# BACKEND_PORT=8000
# FRONTEND_PORT=5173
# DB_PORT=5432
# REDIS_PORT=6379
